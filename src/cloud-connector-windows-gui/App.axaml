<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CloudConnectorWindowsGui.GuiApplication"
             Name="OutSystems Cloud Connector"
             RequestedThemeVariant="Default">
    <NativeMenu.Menu>
        <NativeMenu>
            <NativeMenuItem Header="About OutSystems Cloud Connector" Click="About_OnClick" />
            <NativeMenuItemSeparator />
            <NativeMenuItem Header="Preferences..." Click="Preferences_OnClick" Gesture="Meta+OemComma" />
        </NativeMenu>
    </NativeMenu.Menu>
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>
