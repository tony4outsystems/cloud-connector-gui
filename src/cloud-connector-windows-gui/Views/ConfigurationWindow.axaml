<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CloudConnectorWindowsGui.ViewModels"
        x:Class="CloudConnectorWindowsGui.Views.ConfigurationWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Configuration"
        Width="520" SizeToContent="Height"
        MinWidth="480"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="20" RowDefinitions="Auto,Auto,Auto">
        <Grid Grid.Row="0" ColumnDefinitions="150,*" Margin="0,0,0,16">
            <TextBlock Grid.Column="0" Text="GUI update check" VerticalAlignment="Center" Margin="0,4,8,4" />
            <ComboBox Grid.Column="1" ItemsSource="{Binding SelfUpdateIntervalOptions}" SelectedItem="{Binding SelfUpdateCheckInterval}" IsEnabled="{Binding CanEditConfiguration}" Margin="0,4" />
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="Auto,*" Margin="0,0,0,16">
            <Button Grid.Column="0" Content="Download / Update Binary" Command="{Binding InstallOrUpdateBinaryCommand}" IsEnabled="{Binding CanUpdateBinary}" MinWidth="190" />
            <TextBlock Grid.Column="1" Text="{Binding BinaryVersionText}" VerticalAlignment="Center" Margin="12,0,0,0" TextWrapping="Wrap" />
        </Grid>

        <Button Grid.Row="2" Content="Close" HorizontalAlignment="Right" MinWidth="80" IsDefault="True" IsCancel="True" Click="Close_OnClick" />
    </Grid>
</Window>
